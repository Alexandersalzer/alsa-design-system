{
  "name": "@blimpify-im/ui",
  "version": "3.2.376",
  "description": "Blimpify Design System - Reusable React components for client websites",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/design/system/core/config/index.js",
      "require": "./dist/design/system/core/config/index.js",
      "types": "./dist/design/system/core/config/index.d.ts"
    },
    "./apps": {
      "import": "./dist/design/system/core/ApplicationComponent/index.js",
      "require": "./dist/design/system/core/ApplicationComponent/index.js",
      "types": "./dist/design/system/core/ApplicationComponent/index.d.ts"
    },
    "./apps/server": {
      "import": "./dist/design/system/core/applications/index.js",
      "require": "./dist/design/system/core/applications/index.js",
      "types": "./dist/design/system/core/applications/index.d.ts"
    },
    "./content": {
      "import": "./dist/design/system/core/content/index.js",
      "require": "./dist/design/system/core/content/index.js",
      "types": "./dist/design/system/core/content/index.d.ts"
    },
    "./shells": {
      "import": "./dist/design/system/shells/index.js",
      "require": "./dist/design/system/shells/index.js",
      "types": "./dist/design/system/shells/index.d.ts"
    },
    "./design": {
      "import": "./dist/design/system/core/design/index.js",
      "require": "./dist/design/system/core/design/index.js",
      "types": "./dist/design/system/core/design/index.d.ts"
    },
    "./routing": {
      "import": "./dist/design/system/core/routing/index.js",
      "require": "./dist/design/system/core/routing/index.js",
      "types": "./dist/design/system/core/routing/index.d.ts"
    },
    "./dist/index.css": "./dist/design/index.css"
  },
  "files": [
    "dist",
    "design/system/core/scripts/generateConfig.js"
  ],
  "scripts": {
    "generate:config": "tsx node_modules/@blimpify-im/ui/dist/design/system/core/scripts/generateConfig.js",
    "validate:css": "node validate-css.js",
    "validate:content": "tsx design/system/core/scripts/validateContent.ts",
    "prebuild": "npm run validate:css",
    "build": "npm run build:ts && npm run build:css",
    "build:ts": "tsc",
    "build:css": "find design -name '*.css' | while read file; do target=\"dist/$file\"; mkdir -p \"$(dirname \"$target\")\"; cp \"$file\" \"$target\"; done",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blimpify-IM/blimpify-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "ui",
    "blimpify"
  ],
  "author": "Blimpify",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@blimpify-im/ui": "^3.1.549",
    "@heroicons/react": "^2.2.0",
    "@internationalized/date": "^3.10.0",
    "@react-aria/button": "^3.14.2",
    "@react-aria/calendar": "^3.9.2",
    "@react-aria/datepicker": "^3.15.2",
    "@react-aria/focus": "^3.21.2",
    "@react-aria/i18n": "^3.12.13",
    "@react-aria/interactions": "^3.25.6",
    "@react-aria/overlays": "^3.30.0",
    "@react-aria/slider": "^3.8.2",
    "@react-aria/utils": "^3.31.0",
    "@react-aria/visually-hidden": "^3.8.28",
    "@react-stately/calendar": "^3.9.0",
    "@react-stately/datepicker": "^3.15.2",
    "@react-stately/slider": "^3.7.2",
    "@studio-freight/lenis": "^1.0.42",
    "country-flag-icons": "^1.5.21",
    "lenis": "^1.3.11",
    "lucide-react": "^0.525.0",
    "react-easy-crop": "^5.5.6",
    "react-image-crop": "^11.0.10",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-easy-crop": "^1.16.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "next": "^15.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
