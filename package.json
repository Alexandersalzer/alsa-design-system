{
  "name": "@blimpify-im/ui",
  "version": "3.2.169",
  "description": "Blimpify Design System - Reusable React components for client websites",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./i18n": {
      "import": "./dist/design/system/core/routing/i18n.js",
      "require": "./dist/design/system/core/routing/i18n.js",
      "types": "./dist/design/system/core/routing/i18n.d.ts"
    },
    "./content": {
      "import": "./dist/design/system/core/render/contentLoader.js",
      "require": "./dist/design/system/core/render/contentLoader.js",
      "types": "./dist/design/system/core/render/contentLoader.d.ts"
    },
    "./client": {
      "import": "./dist/design/system/templates/index.js",
      "require": "./dist/design/system/templates/index.js",
      "types": "./dist/design/system/templates/index.d.ts"
    },
    "./design": {
      "import": "./dist/design/system/core/design/index.js",
      "require": "./dist/design/system/core/design/index.js",
      "types": "./dist/design/system/core/design/index.d.ts"
    },
    "./postmessage": {
      "import": "./dist/design/system/core/postmessage/index.js",
      "require": "./dist/design/system/core/postmessage/index.js",
      "types": "./dist/design/system/core/postmessage/index.d.ts"
    },
    "./dist/index.css": "./dist/design/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "validate:css": "node validate-css.js",
    "prebuild": "npm run validate:css",
    "build": "npm run build:ts && npm run build:css",
    "build:ts": "tsc",
    "build:css": "find design -name '*.css' | while read file; do target=\"dist/$file\"; mkdir -p \"$(dirname \"$target\")\"; cp \"$file\" \"$target\"; done",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blimpify-IM/blimpify-ui.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "ui",
    "blimpify"
  ],
  "author": "Blimpify",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@internationalized/date": "^3.10.0",
    "@react-aria/button": "^3.14.2",
    "@react-aria/calendar": "^3.9.2",
    "@react-aria/datepicker": "^3.15.2",
    "@react-aria/i18n": "^3.12.13",
    "@react-aria/overlays": "^3.30.0",
    "@react-stately/calendar": "^3.9.0",
    "@react-stately/datepicker": "^3.15.2",
    "@studio-freight/lenis": "^1.0.42",
    "country-flag-icons": "^1.5.21",
    "lenis": "^1.3.11",
    "lucide-react": "^0.525.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "next": "^15.0.0",
    "typescript": "^5.9.3"
  }
}
